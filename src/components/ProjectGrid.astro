---
import { getFeaturedProjects } from '../utils/projects';

const featuredProjects = await getFeaturedProjects();
---

<div class="project-grid">
  {featuredProjects.map((project) => {
    const d = project.data;
    const primaryHref = d.hasWriteup ? `/projects/${project.slug}` : (d.liveUrl || d.externalUrl || d.githubUrl || '#');
    const primaryInternal = d.hasWriteup;
    const primaryLabel = d.hasWriteup ? 'Read More' : 'View Project';
    return (
    <div class="project-card">
      <div class="card-glow"></div>
      <div class="project-image">
        <a href={primaryHref} class="image-link" target={primaryInternal ? '_self' : '_blank'} rel={primaryInternal ? '' : 'noopener noreferrer'}>
          <img src={d.image} alt={d.imageAlt} />
          <div class="read-more-overlay">
            <span>{primaryLabel}</span>
          </div>
        </a>
      </div>
      <div class="project-content">
        <h3><a href={`/projects/${project.slug}`} class="title-link">{d.title}</a></h3>
        <p class="project-description">
          {d.description.length > 100 ? d.description.slice(0, 100) + '...' : d.description}
        </p>
        <div class="project-tags">
          {d.technologies.slice(0, 3).map((tech) => (
            <span class="tag-pill">{tech}</span>
          ))}
        </div>
        <div class="project-links">
          <a href={primaryHref} class="btn btn-primary" target={primaryInternal ? '_self' : '_blank'} rel={primaryInternal ? '' : 'noopener noreferrer'}>
            {primaryLabel}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          {d.blogUrl && (
            <a href={d.blogUrl} class="btn btn-ghost" target="_self">
              Read More
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
            </a>
          )}
          {d.githubUrl && d.githubUrl !== primaryHref && (
            <a href={d.githubUrl} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
              GitHub
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.28 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
      <div class="card-hover-line"></div>
    </div>
    );
  })}
</div>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: 2rem 0;
  }

  @media (max-width: 900px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  .project-card {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: var(--glass-shadow);
    transition: transform 0.35s cubic-bezier(0.19, 1, 0.22, 1), box-shadow 0.35s cubic-bezier(0.19, 1, 0.22, 1);
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-hover-shadow);
  }

  .card-glow {
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--primary-color), var(--secondary-color), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 2;
  }

  .project-card:hover .card-glow {
    opacity: 1;
  }

  .card-hover-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .project-card:hover .card-hover-line {
    transform: scaleX(1);
  }

  .project-image {
    height: 200px;
    position: relative;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .image-link {
    display: block;
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  .read-more-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 26, 0.75);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.19, 1, 0.22, 1);
    backdrop-filter: blur(2px);
  }

  .read-more-overlay span {
    padding: 0.4rem 1rem;
    border: 1px solid rgba(100, 255, 218, 0.4);
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 0.75rem;
    transform: translateY(12px);
    transition: transform 0.35s cubic-bezier(0.19, 1, 0.22, 1);
    color: var(--primary-color);
    letter-spacing: 0.03em;
  }

  .image-link:hover .read-more-overlay {
    opacity: 1;
  }

  .image-link:hover .read-more-overlay span {
    transform: translateY(0);
  }

  .project-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 0.5rem;
  }

  .project-content h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .title-link {
    color: var(--color-heading);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .project-card:hover .title-link {
    color: var(--primary-color);
  }

  .project-description {
    color: var(--color-text-alt);
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: 100px;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--primary-color);
    background: rgba(100, 255, 218, 0.08);
    border: 1px solid rgba(100, 255, 218, 0.15);
  }

  [data-theme="light"] .tag-pill {
    background: rgba(8, 145, 178, 0.08);
    border-color: rgba(8, 145, 178, 0.15);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-sm);
    font-size: 0.78rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
    border: 1px solid transparent;
  }

  .btn-primary {
    background: rgba(100, 255, 218, 0.1);
    color: var(--primary-color);
    border-color: rgba(100, 255, 218, 0.2);
  }

  .btn-primary:hover {
    background: var(--primary-color);
    color: var(--color-bg);
    border-color: var(--primary-color);
    box-shadow: var(--glow-primary);
  }

  [data-theme="light"] .btn-primary {
    background: rgba(8, 145, 178, 0.08);
    border-color: rgba(8, 145, 178, 0.2);
  }

  [data-theme="light"] .btn-primary:hover {
    background: var(--primary-color);
    color: #ffffff;
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text-alt);
    border-color: var(--glass-border);
  }

  .btn-ghost:hover {
    color: var(--color-heading);
    border-color: var(--color-text-dim);
  }
</style>
