---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Comments from '../../components/Comments.astro';
import StructuredData from '../../components/StructuredData.astro';

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }) => {
    // Filter out draft posts
    return !data.draft;
  });

  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get blog post data from the props
const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// Format the publication date
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(entry.data.pubDate);

// Calculate reading time
const wordsPerMinute = 200;
const words = entry.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / wordsPerMinute));

// Filter headings for sidebar TOC (h2 and h3 only)
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// SEO: default OG image when the post has no hero image
const defaultImage = '/profile-top.jpg';
const ogImage = entry.data.heroImage ?? defaultImage;

// Canonical URL for this post (used in JSON-LD)
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const absoluteImage = new URL(ogImage, Astro.site).toString();

// JSON-LD BlogPosting structured data
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Antiraedus',
  },
  ...(entry.data.heroImage ? { image: absoluteImage } : {}),
  url: canonicalURL,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
};
---

<Layout
  title={`${entry.data.title} | Blog | Antiraedus`}
  description={entry.data.description}
  image={ogImage}
  type="article"
  publishedTime={entry.data.pubDate.toISOString()}
  tags={entry.data.tags}
>
  <StructuredData data={structuredData} />
  <!-- Reading Progress Bar -->
  <div class="progress-bar-container">
    <div class="progress-bar" id="reading-progress"></div>
  </div>

  <main class="blog-post">
    <article>
      <div class="post-layout">
        <!-- Sidebar TOC (desktop only) -->
        {tocHeadings.length > 2 && (
          <aside class="toc-sidebar" id="toc-sidebar">
            <nav class="toc-nav">
              <div class="toc-label">On this page</div>
              <ul class="toc-list">
                {tocHeadings.map(heading => (
                  <li class={`toc-item toc-depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`} class="toc-link">{heading.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}

        <div class="post-main">
          <div class="blog-header">
            <a href="/blog" class="back-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
              </svg>
              Back to Blog
            </a>

            <h1>{entry.data.title}</h1>

            <div class="blog-meta">
              <span class="publish-date">
                <time datetime={entry.data.pubDate.toISOString()}>
                  {formattedDate}
                </time>
              </span>
              {entry.data.author && <span class="author">by {entry.data.author}</span>}
              <span class="reading-time">{readingTime} min read</span>
            </div>

            {entry.data.tags && entry.data.tags.length > 0 && (
              <div class="header-tags">
                {entry.data.tags.map((tag: string) => (
                  <a href={`/blog/tag/${tag}`} class="header-tag">#{tag}</a>
                ))}
              </div>
            )}

            {entry.data.heroImage && (
              <div class="featured-image">
                <img src={entry.data.heroImage} alt={entry.data.title} />
              </div>
            )}
          </div>

          <div class="blog-content">
            <Content />
          </div>

          {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="blog-tags-footer">
              <div class="tags-divider"></div>
              <div class="tag-list">
                {entry.data.tags.map((tag: string) => (
                  <a href={`/blog/tag/${tag}`} class="tag">#{tag}</a>
                ))}
              </div>
            </div>
          )}

          <Comments />

          <div class="blog-navigation">
            <a href="/blog" class="btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
              </svg>
              Back to All Posts
            </a>
          </div>
        </div>
      </div>
    </article>
  </main>
</Layout>

<script>
  // Reading progress bar
  function updateProgress() {
    const progressBar = document.getElementById('reading-progress');
    if (!progressBar) return;

    const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = window.scrollY;
    const progress = Math.min((scrolled / docHeight) * 100, 100);
    progressBar.style.width = `${progress}%`;
  }

  // Sticky TOC with active section tracking
  function initTOC() {
    const sidebar = document.getElementById('toc-sidebar');
    const tocLinks = document.querySelectorAll('.toc-link');
    if (!sidebar || tocLinks.length === 0) return;

    const headerHeight = 80;

    // Track active section
    const headingElements = Array.from(tocLinks).map(link => {
      const id = link.getAttribute('href')?.slice(1);
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    function updateActiveSection() {
      const scrollPos = window.scrollY + headerHeight + 40;

      let activeIndex = -1;
      for (let i = headingElements.length - 1; i >= 0; i--) {
        if (headingElements[i].offsetTop <= scrollPos) {
          activeIndex = i;
          break;
        }
      }

      tocLinks.forEach((link, index) => {
        if (index === activeIndex) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    }

    // Show/hide TOC based on scroll position
    const blogHeader = document.querySelector('.blog-header');
    function updateTOCVisibility() {
      if (!blogHeader) return;
      const headerBottom = blogHeader.getBoundingClientRect().bottom;
      if (headerBottom < 0) {
        sidebar.classList.add('visible');
      } else {
        sidebar.classList.remove('visible');
      }
    }

    window.addEventListener('scroll', () => {
      updateActiveSection();
      updateTOCVisibility();
    }, { passive: true });

    updateActiveSection();
    updateTOCVisibility();
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  window.addEventListener('resize', updateProgress, { passive: true });
  updateProgress();

  document.addEventListener('DOMContentLoaded', initTOC);
  // Also run on astro page load for view transitions
  document.addEventListener('astro:page-load', () => {
    updateProgress();
    initTOC();
  });
</script>

<style>
  /* ---- Progress Bar ---- */
  .progress-bar-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 200;
    background: transparent;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
    transition: width 0.1s linear;
    box-shadow: 0 0 8px rgba(100, 255, 218, 0.4);
  }

  [data-theme="light"] .progress-bar {
    box-shadow: 0 0 8px rgba(8, 145, 178, 0.3);
  }

  /* ---- Post Layout ---- */
  .blog-post {
    padding: 4rem 0 4rem;
  }

  .post-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    position: relative;
  }

  .post-main {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  /* ---- Sidebar TOC ---- */
  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1280px) {
    /* Only widen to two columns when a TOC actually exists, so TOC-less
       posts keep their centered single-column layout. */
    .post-layout:has(.toc-sidebar) {
      grid-template-columns: minmax(0, 1fr) 200px;
      column-gap: 3rem;
      max-width: 1180px;
    }

    .post-layout:has(.toc-sidebar) .post-main {
      grid-column: 1;
      min-width: 0;
    }

    .toc-sidebar {
      display: block;
      grid-column: 2;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .toc-sidebar.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .toc-nav {
      position: sticky;
      top: 100px;
      max-height: calc(100vh - 140px);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--color-border) transparent;
    }

    .toc-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-text-dim);
      margin-bottom: 0.75rem;
      padding-left: 0.75rem;
    }

    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      border-left: 1px solid var(--color-border);
    }

    .toc-item {
      margin: 0;
    }

    .toc-depth-3 {
      padding-left: 0.75rem;
    }

    .toc-link {
      display: block;
      padding: 0.35rem 0.75rem;
      font-size: 0.78rem;
      line-height: 1.4;
      color: var(--color-text-dim);
      text-decoration: none;
      border-left: 2px solid transparent;
      margin-left: -1px;
      transition: color 0.2s ease, border-color 0.2s ease;
    }

    .toc-link:hover {
      color: var(--color-text);
    }

    .toc-link.active {
      color: var(--primary-color);
      border-left-color: var(--primary-color);
    }
  }

  /* ---- Blog Header ---- */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-text-dim);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .back-link:hover {
    color: var(--primary-color);
    gap: 0.6rem;
  }

  .blog-header {
    margin-bottom: 3rem;
  }

  .blog-header h1 {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    color: var(--color-heading);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
    color: var(--color-text-dim);
    font-size: 0.9rem;
  }

  .blog-meta > span:not(:last-child)::after {
    content: "\00b7";
    margin-left: 0.5rem;
    opacity: 0.5;
  }

  .reading-time {
    color: var(--primary-color);
    font-weight: 500;
  }

  .header-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .header-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--primary-color);
    background: rgba(100, 255, 218, 0.08);
    border: 1px solid rgba(100, 255, 218, 0.15);
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .header-tag:hover {
    background: rgba(100, 255, 218, 0.15);
    transform: translateY(-1px);
  }

  [data-theme="light"] .header-tag {
    background: rgba(8, 145, 178, 0.08);
    border-color: rgba(8, 145, 178, 0.15);
  }

  [data-theme="light"] .header-tag:hover {
    background: rgba(8, 145, 178, 0.15);
  }

  .featured-image {
    margin: 2rem 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ---- Blog Content ---- */
  .blog-content {
    line-height: 1.8;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .blog-content :global(h1),
  .blog-content :global(h2),
  .blog-content :global(h3),
  .blog-content :global(h4) {
    color: var(--color-heading);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .blog-content :global(h2) {
    font-size: 2rem;
    font-weight: 700;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .blog-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-alt);
  }

  .blog-content :global(p) {
    margin-bottom: 1.5rem;
    text-align: justify;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .blog-content :global(li) {
    margin-bottom: 0.5rem;
  }

  /* ---- Enhanced Blockquotes ---- */
  .blog-content :global(blockquote) {
    position: relative;
    border-left: 3px solid var(--primary-color);
    margin: 2rem 0;
    padding: 1.25rem 1.5rem 1.25rem 1.5rem;
    background: linear-gradient(135deg, rgba(100, 255, 218, 0.04), rgba(168, 85, 247, 0.02));
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    box-shadow: inset 0 0 30px rgba(100, 255, 218, 0.02);
  }

  [data-theme="light"] .blog-content :global(blockquote) {
    background: linear-gradient(135deg, rgba(8, 145, 178, 0.04), rgba(124, 58, 237, 0.02));
    box-shadow: inset 0 0 30px rgba(8, 145, 178, 0.02);
  }

  .blog-content :global(blockquote)::before {
    content: "\201C";
    position: absolute;
    top: -0.3rem;
    left: 0.75rem;
    font-size: 3rem;
    color: var(--primary-color);
    opacity: 0.2;
    font-family: Georgia, serif;
    line-height: 1;
  }

  .blog-content :global(code) {
    background-color: var(--color-bg-alt);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--primary-color);
  }

  .blog-content :global(pre) {
    background-color: var(--color-bg-alt) !important;
    border-radius: var(--radius-md);
    margin: 2rem 0;
    padding: 1.5rem;
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }

  .blog-content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  .blog-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-md);
    margin: 2rem auto;
    display: block;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .blog-content :global(iframe) {
    display: block;
    margin: 2rem auto;
    max-width: 100%;
    border-radius: var(--radius-md);
  }

  .blog-content :global(a) {
    color: var(--primary-color);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all 0.2s ease;
  }

  .blog-content :global(a:hover) {
    border-bottom-color: var(--primary-color);
  }

  .blog-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    margin: 3rem 0;
  }

  /* ---- Inline TOC styling (for posts that have TOC in content) ---- */
  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul) {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-left: 3px solid var(--primary-color);
    padding: 1.5rem;
    margin: 1.5rem 0;
    border-radius: var(--radius-md);
    position: relative;
    list-style: none !important;
    padding-left: 0 !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .blog-content :global(ul:has(li > a[href^="#"]):first-child),
  .blog-content :global(h1 + ul:has(li > a[href^="#"])),
  .blog-content :global(h2 + ul:has(li > a[href^="#"])),
  .blog-content :global(h3 + ul:has(li > a[href^="#"])) {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-left: 3px solid var(--primary-color);
    padding: 1.5rem;
    margin: 1.5rem 0;
    border-radius: var(--radius-md);
    position: relative;
    list-style: none !important;
    padding-left: 0 !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .blog-content :global(ul:has(li > a[href^="#"]):first-child::before),
  .blog-content :global(h1 + ul:has(li > a[href^="#"])::before),
  .blog-content :global(h2 + ul:has(li > a[href^="#"])::before),
  .blog-content :global(h3 + ul:has(li > a[href^="#"])::before) {
    content: "Contents";
    display: block;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 1rem;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul::before),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul::before),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul::before) {
    content: "Contents";
    display: block;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 1rem;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul li),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul li),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul li) {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
    position: relative;
    list-style: none;
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul li::before),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul li::before),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul li::before) {
    content: "\25B8";
    position: absolute;
    left: 0;
    color: var(--primary-color);
    font-weight: normal;
    transition: transform 0.2s ease;
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul li:hover::before),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul li:hover::before),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul li:hover::before) {
    transform: translateX(4px);
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul a),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul a),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul a) {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 400;
    border-bottom: none;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul a:hover),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul a:hover),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul a:hover) {
    color: var(--primary-color);
    transform: translateX(2px);
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul ul),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul ul),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul ul) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
    list-style: none;
  }

  .blog-content :global(h1:is([id*="content"], [id*="toc"]) + ul ul li::before),
  .blog-content :global(h2:is([id*="content"], [id*="toc"]) + ul ul li::before),
  .blog-content :global(h3:is([id*="content"], [id*="toc"]) + ul ul li::before) {
    content: "\2022";
    color: var(--color-text-dim);
    font-size: 0.8rem;
  }

  /* ---- Tags Footer ---- */
  .blog-tags-footer {
    margin-top: 3rem;
  }

  .tags-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    margin-bottom: 1.5rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(100, 255, 218, 0.06);
    border: 1px solid rgba(100, 255, 218, 0.12);
    border-radius: 100px;
    color: var(--primary-color);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  [data-theme="light"] .tag {
    background: rgba(8, 145, 178, 0.06);
    border-color: rgba(8, 145, 178, 0.12);
  }

  .tag:hover {
    background: var(--primary-color);
    color: var(--color-bg);
    border-color: var(--primary-color);
    transform: translateY(-1px);
  }

  /* ---- Navigation ---- */
  .blog-navigation {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--glass-bg);
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 500;
    transition: all 0.2s ease;
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .btn:hover {
