---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { formatProjectDate, getStatusBadgeClass, getProjectDuration } from '../../utils/projects';

// Generate static paths for all projects
export async function getStaticPaths() {
  const projectEntries = await getCollection('projects');

  return projectEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get project data from the props
const { entry } = Astro.props;

// If project doesn't have a writeup, redirect to external URL
if (!entry.data.hasWriteup) {
  const externalUrl = entry.data.externalUrl || entry.data.liveUrl || entry.data.githubUrl;
  if (externalUrl) {
    return Astro.redirect(externalUrl);
  }
}

const { Content } = await entry.render();

// Format dates
const startDate = formatProjectDate(entry.data.startDate);
const endDate = entry.data.endDate ? formatProjectDate(entry.data.endDate) : 'Present';
const duration = getProjectDuration(entry.data.startDate, entry.data.endDate);
---

<Layout title={`${entry.data.title} | Projects | Antiraedus`} description={entry.data.description} image={entry.data.image}>
  <main class="project-detail">
    <article>
      <div class="container">
        <div class="project-header">
          <a href="/projects" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back to Projects
          </a>

          <h1>{entry.data.title}</h1>

          <div class="project-meta">
            <div class={`status-badge ${getStatusBadgeClass(entry.data.status)}`}>
              {entry.data.status}
            </div>
            <div class="project-timeline">
              <span class="timeline-dates">{startDate} - {endDate}</span>
              <span class="timeline-duration">({duration})</span>
            </div>
          </div>

          <div class="project-actions">
            {entry.data.liveUrl && (
              <a href={entry.data.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                View Live Project
              </a>
            )}
            {entry.data.githubUrl && (
              <a href={entry.data.githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                Source Code
              </a>
            )}
          </div>
        </div>

        <div class="project-hero">
          <img src={entry.data.image} alt={entry.data.imageAlt} class="hero-image" />
        </div>

        <div class="project-tags-container">
          <div class="tag-group">
            <h3 class="tag-title">Technologies</h3>
            <div class="project-tags">
              {entry.data.technologies.map((tech: string) => (
                <span class="tag-pill">{tech}</span>
              ))}
            </div>
          </div>

          <div class="tag-group">
            <h3 class="tag-title">Category</h3>
            <span class="category-pill">{entry.data.category}</span>
          </div>
        </div>

        <div class="case-study-intro">
          <h2 class="case-study-heading">Case Study</h2>
          <p class="intro-text">Explore the detailed case study below to learn about the challenges, solutions, and outcomes of this project.</p>
          <div class="intro-accent"></div>
        </div>

        <div class="project-content">
          <Content />
        </div>

        <div class="project-navigation">
          <a href="/projects" class="btn btn-back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back to All Projects
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>

<style>
  /* ---- Layout ---- */
  .project-detail {
    padding: 4rem 0 4rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ---- Back Link ---- */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-text-dim);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .back-link:hover {
    color: var(--primary-color);
    gap: 0.6rem;
  }

  /* ---- Header ---- */
  .project-header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    color: var(--color-heading);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  /* ---- Meta ---- */
  .project-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  /* ---- Status Badges ---- */
  .status-badge {
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .status-completed {
    background: rgba(16, 185, 129, 0.15);
    color: #34d399;
    border: 1px solid rgba(16, 185, 129, 0.25);
  }

  .status-in-progress {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.25);
  }

  .status-planned {
    background: rgba(99, 102, 241, 0.15);
    color: #a5b4fc;
    border: 1px solid rgba(99, 102, 241, 0.25);
  }

  [data-theme="light"] .status-completed {
    background: rgba(16, 185, 129, 0.1);
    color: #059669;
    border-color: rgba(16, 185, 129, 0.2);
  }

  [data-theme="light"] .status-in-progress {
    background: rgba(245, 158, 11, 0.1);
    color: #d97706;
    border-color: rgba(245, 158, 11, 0.2);
  }

  [data-theme="light"] .status-planned {
    background: rgba(99, 102, 241, 0.1);
    color: #4f46e5;
    border-color: rgba(99, 102, 241, 0.2);
  }

  .project-timeline {
    font-size: 0.9rem;
    color: var(--color-text-dim);
  }

  .timeline-duration {
    margin-left: 0.5rem;
    font-style: italic;
    color: var(--color-text-alt);
  }

  /* ---- Action Buttons ---- */
  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
    border: 1px solid transparent;
  }

  .btn-primary {
    background: rgba(100, 255, 218, 0.1);
    color: var(--primary-color);
    border-color: rgba(100, 255, 218, 0.2);
  }

  .btn-primary:hover {
    background: var(--primary-color);
    color: var(--color-bg);
    border-color: var(--primary-color);
    box-shadow: var(--glow-primary);
    transform: translateY(-2px);
  }

  [data-theme="light"] .btn-primary {
    background: rgba(8, 145, 178, 0.08);
    border-color: rgba(8, 145, 178, 0.2);
  }

  [data-theme="light"] .btn-primary:hover {
    background: var(--primary-color);
    color: #ffffff;
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text-alt);
    border-color: var(--glass-border);
  }

  .btn-ghost:hover {
    color: var(--color-heading);
    border-color: var(--color-text-dim);
    background: rgba(255, 255, 255, 0.03);
    transform: translateY(-2px);
  }

  .btn-back {
    background: var(--glass-bg);
    color: var(--color-text);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .btn-back:hover {
    background: var(--primary-color);
    color: #ffffff;
    border-color: var(--primary-color);
    transform: translateY(-1px);
    box-shadow: var(--glow-primary);
  }

  /* ---- Hero Image ---- */
  .project-hero {
    margin-bottom: 2.5rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
    border: 1px solid var(--glass-border);
    position: relative;
  }

  .hero-image {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    display: block;
  }

  /* ---- Tags Container ---- */
  .project-tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .tag-group {
    flex: 1;
    min-width: 200px;
  }

  .tag-title {
    margin-top: 0;
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--primary-color);
    background: rgba(100, 255, 218, 0.08);
    border: 1px solid rgba(100, 255, 218, 0.15);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  [data-theme="light"] .tag-pill {
    background: rgba(8, 145, 178, 0.08);
    border-color: rgba(8, 145, 178, 0.15);
  }

  .category-pill {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--secondary-color);
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.15);
  }

  [data-theme="light"] .category-pill {
    background: rgba(124, 58, 237, 0.08);
    border-color: rgba(124, 58, 237, 0.15);
  }

  /* ---- Case Study Intro ---- */
  .case-study-intro {
    margin: 2rem 0 2.5rem;
    text-align: center;
    padding-bottom: 2rem;
  }

  .case-study-heading {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
    color: var(--color-heading);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .intro-text {
    font-size: 1.05rem;
    color: var(--color-text-alt);
    max-width: 600px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
  }

  .intro-accent {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
    margin: 0 auto;
    border-radius: 2px;
  }

  /* ---- Project Content (matches blog typography) ---- */
  .project-content {
    line-height: 1.8;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .project-content :global(h1),
  .project-content :global(h2),
  .project-content :global(h3),
  .project-content :global(h4) {
    color: var(--color-heading);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .project-content :global(h2) {
    font-size: 2rem;
    font-weight: 700;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .project-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .project-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-alt);
  }

  .project-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .project-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .project-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-md);
    margin: 2rem auto;
    display: block;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .project-content :global(code) {
    background-color: var(--color-bg-alt);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--primary-color);
  }

  .project-content :global(pre) {
    background-color: var(--color-bg-alt) !important;
    border-radius: var(--radius-md);
    margin: 2rem 0;
    padding: 1.5rem;
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }

  .project-content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  .project-content :global(blockquote) {
    position: relative;
    border-left: 3px solid var(--primary-color);
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(135deg, rgba(100, 255, 218, 0.04), rgba(168, 85, 247, 0.02));
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
  }

  [data-theme="light"] .project-content :global(blockquote) {
    background: linear-gradient(135deg, rgba(8, 145, 178, 0.04), rgba(124, 58, 237, 0.02));
  }

  .project-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    margin: 3rem 0;
  }

  .project-content :global(a) {
    color: var(--primary-color);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all 0.2s ease;
  }

  .project-content :global(a:hover) {
    border-bottom-color: var(--primary-color);
  }

  /* ---- Navigation ---- */
  .project-navigation {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    .project-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .project-tags-container {
      flex-direction: column;
      gap: 1.5rem;
    }

    .tag-group {
      min-width: auto;
    }

    .project-content {
      font-size: 1rem;
    }

    .project-content :global(h2) {
      font-size: 1.5rem;
    }

    .project-content :global(h3) {
      font-size: 1.3rem;
    }

    .project-content :global(blockquote) {
      padding: 1rem;
      margin: 1.5rem 0;
    }
  }
</style>
